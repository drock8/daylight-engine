{
  "name": "hacker-bob",
  "version": "1.3.5",
  "description": "Portable autonomous bug bounty hunting MCP framework with host adapters",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vmihalis/hacker-bob.git"
  },
  "bugs": {
    "url": "https://github.com/vmihalis/hacker-bob/issues"
  },
  "homepage": "https://github.com/vmihalis/hacker-bob#readme",
  "bin": {
    "hacker-bob": "bin/hacker-bob.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    ".claude/agents/**/*",
    ".claude/bob/egress-profiles.example.json",
    ".claude/commands/**/*",
    ".claude/hooks/bob-check-update-worker.js",
    ".claude/hooks/bob-check-update.js",
    ".claude/hooks/bob-egress.js",
    ".claude/hooks/bob-export.js",
    ".claude/hooks/bob-update.js",
    ".claude/hooks/bounty-statusline.js",
    ".claude/hooks/hunter-subagent-stop.js",
    ".claude/hooks/session-read-guard.sh",
    ".claude/hooks/session-write-guard.sh",
    ".claude/rules/**/*",
    ".claude/settings.json",
    ".claude/skills/**/*",
    ".hacker-bob/bypass-tables/**/*",
    ".hacker-bob/knowledge/**/*",
    "adapters/**/*",
    "bin/**/*.js",
    "docs/**/*.md",
    "!docs/refactor-*.md",
    "docs/**/*.html",
    "docs/**/*.png",
    "mcp/**/*",
    "prompts/**/*",
    "scripts/**/*.js",
    "scripts/**/*.mjs",
    "scripts/**/*.sh",
    "!scripts/authority-inventory.js",
    "testing/policy-replay/**/*",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "DISCLAIMER.md",
    "LICENSE",
    "NOTICE",
    "README.md",
    "SECURITY.md",
    "install.sh",
    "!**/*.apk",
    "!**/*.aab",
    "!**/*.xapk",
    "!**/*.ipa",
    "!**/*.app",
    "!**/*.pcap",
    "!**/*.pcapng",
    "!**/*.sqlite",
    "!**/*.sqlite3",
    "!**/*.db",
    "!**/mobile-apps/**",
    "!**/mobile-traces/**",
    "!**/screenshots/**",
    "!**/device-logs/**",
    "!**/app-containers/**",
    "!**/mobile-artifacts.jsonl",
    "!**/mobile-static-scan-results.jsonl",
    "!**/mobile-device-profiles.jsonl",
    "!**/mobile-device-leases.jsonl"
  ],
  "scripts": {
    "check:syntax": "find mcp .claude/hooks -type f -name '*.js' -print0 | xargs -0 -n1 node --check",
    "check:agent-tools": "node scripts/generate-agent-tools.js --check",
    "check:authority-inventory": "node scripts/authority-inventory.js --check",
    "check:skill": "node scripts/generate-bountyagent-skill.js --check",
    "test:mcp": "node scripts/run-mcp-tests.js",
    "test:prompts": "npm run check:agent-tools && npm run check:skill && node --test test/prompt-contracts.test.js",
    "test:install": "node --test test/install-smoke.test.js",
    "test:update": "node --test test/update-check.test.js",
    "test:cli": "node --test test/cli.test.js",
    "test:adapter-detection": "node --test test/adapter-detection.test.js",
    "test:package": "node --test test/package.test.js",
    "test:policy-replay": "node --test test/policy-replay.test.js",
    "test:hooks": "python3 test/test-write-guard.py && python3 test/test-read-guard.py",
    "test": "npm run check:syntax && npm run check:authority-inventory && npm run test:mcp && npm run test:prompts && npm run test:install && npm run test:update && npm run test:cli && npm run test:adapter-detection && npm run test:package && npm run release:check:clean && npm run test:policy-replay && npm run test:hooks",
    "release:check": "node scripts/release-check.js",
    "release:check:dependencies": "node scripts/dependency-freshness.js",
    "release:check:clean": "node scripts/clean-release-audit.js",
    "release:check:registry": "node scripts/release-check.js --registry && node scripts/dependency-freshness.js",
    "replay:policy": "node testing/policy-replay/replay.mjs",
    "install-browser": "npx patchright install chromium"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.132",
    "proxy-agent": "^8.0.1",
    "psl": "^1.15.0"
  },
  "optionalDependencies": {
    "patchright": "^1.59.4"
  }
}
